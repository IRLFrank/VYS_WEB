@{
    ViewData["Title"] = "Registrace";
}

<div class="register-container">
    <h1 class="nadpis">Registrace</h1>
    <hr class="cara">

    <div class="register-form-wrapper">
        <form asp-action="Register" method="post" class="register-form">

            @if (ViewBag.Error != null)
            {
                <div style="color: #ff9185; margin-bottom: 20px; text-align: center; font-size: 16px;">
                    @ViewBag.Error
                </div>
            }

            <div class="form-group">
                <label class="form-label">Jméno</label>
                <input name="firstName" class="form-input" placeholder="Zadejte vaše jméno" value="@ViewBag.FirstName" />
            </div>

            <div class="form-group">
                <label class="form-label">Příjmení</label>
                <input name="lastName" class="form-input" placeholder="Zadejte vaše příjmení" value="@ViewBag.LastName" />
            </div>

            <div class="form-group">
                <label class="form-label">Heslo</label>
                <input name="password" type="password" class="form-input" placeholder="Zadejte heslo (min. 6 znaků)" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-register">Pokračovat na profil</button>
            </div>

            <div class="login-footer">
                <p class="login-text">Již máte účet? <a asp-action="Login" class="login-link">Přihlaste se</a></p>
            </div>
        </form>
    </div>
</div>
