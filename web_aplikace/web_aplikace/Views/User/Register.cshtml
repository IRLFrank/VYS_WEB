@model web_aplikace.Models.UserModel

@{
    ViewData["Title"] = "Registrace";
}

<div class="register-container">
    <h1 class="nadpis">Registrace</h1>
    <hr class="cara">

    <div class="register-form-wrapper">
        <form asp-action="Register" method="post" class="register-form">
            <div class="form-group">
                <label asp-for="FirstName" class="form-label">Jméno</label>
                <input asp-for="FirstName" class="form-input" placeholder="Zadejte vaše jméno" />
                <span asp-validation-for="FirstName" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName" class="form-label">Příjmení</label>
                <input asp-for="LastName" class="form-input" placeholder="Zadejte vaše příjmení" />
                <span asp-validation-for="LastName" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Heslo</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="Zadejte heslo (min. 6 znaků)" />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-register">Pokračovat na profil</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
